# igasm.in website env. Vite only exposes VITE_-prefixed vars to the client.
# The publishable (anon) key is safe to ship: the public can ONLY call the
# join_waitlist RPC (add an email), never read the waitlist back. RLS is the gate.
# Copy this to .env (gitignored) and fill in real values.
VITE_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxx
