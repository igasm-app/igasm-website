<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <script>
      document.documentElement.classList.add("js");
    </script>

    <title>igasm - private intimacy &amp; cycle wellness, coming soon</title>
    <meta
      name="description"
      content="A private, beautifully made companion to understand your intimacy and your menstrual cycle, and see how the two move together. Coming soon to iOS and Android. Encrypted, never sold, never shared."
    />
    <meta name="theme-color" content="#1A1416" />
    <meta name="color-scheme" content="dark" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content="igasm - private intimacy &amp; cycle wellness" />
    <meta property="og:description" content="A private companion to understand your intimacy and your cycle, and see how the two move together. Coming soon to iOS and Android." />
    <meta property="og:url" content="https://igasm.in" />
    <meta property="og:site_name" content="igasm" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="igasm - private intimacy &amp; cycle wellness" />
    <meta name="twitter:description" content="A private companion to understand your intimacy and your cycle. Coming soon." />

    <link rel="icon" href="favicon.svg" type="image/svg+xml" />
    <link rel="apple-touch-icon" href="favicon.svg" />
    <link rel="canonical" href="https://igasm.in" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=Inter:wght@400;500;600&display=swap"
      rel="stylesheet"
    />
    <link rel="stylesheet" href="styles.css" />
  </head>

  <body>
    <div class="bg-fallback" aria-hidden="true"></div>
    <canvas class="bg-gl" aria-hidden="true"></canvas>
    <div class="grain" aria-hidden="true"></div>
    <div class="cursor-glow" aria-hidden="true"></div>

    <header class="nav">
      <a href="#top" class="brand" data-cursor>igasm<sup>&reg;</sup></a>
      <nav class="index" aria-label="Sections">
        <a href="#idea" data-cursor><i>01</i> The idea</a>
        <a href="#cycle" data-cursor><i>02</i> The cycle</a>
        <a href="#private" data-cursor><i>03</i> Private</a>
        <a href="#join" data-cursor><i>04</i> Join</a>
      </nav>
      <a href="#join" class="nav-cta" data-cursor>Get early access</a>
    </header>

    <main>
      <!-- ===================== HERO ===================== -->
      <section class="hero" id="top">
        <p class="hero-eyebrow"><span class="live"><i></i> Waitlist open</span> <span class="d">/</span> coming soon to iOS + Android</p>

        <div class="wordmark-wrap">
          <h1 class="wordmark" aria-label="igasm">
            <span class="wm-base" aria-hidden="true">igasm</span>
            <span class="wm-lit" aria-hidden="true">igasm</span>
          </h1>
          <span class="wm-glow" aria-hidden="true"></span>
        </div>

        <p class="hero-sub">Your intimacy and your cycle, finally read together.</p>

        <form class="waitlist hero-form" aria-label="Join the waitlist">
          <label class="sr-only" for="email-hero">Your email address</label>
          <div class="field">
            <input id="email-hero" type="email" name="email" inputmode="email" autocomplete="email" required placeholder="you@email.com" aria-describedby="note-hero" />
            <button type="submit" class="cta" data-cursor><span>Get early access</span><span class="arr">&rarr;</span></button>
          </div>
          <p class="form-note" id="note-hero" role="status" aria-live="polite"></p>
        </form>

        <a class="scroll-cue" href="#idea" data-cursor><span>Scroll</span><span class="cue-line"></span></a>
      </section>

      <!-- ===================== 01 THE IDEA ===================== -->
      <section class="block" id="idea">
        <header class="block-head"><span class="num">01</span><span class="lbl">The idea</span></header>
        <div class="block-body">
          <h2 class="big reveal">Most apps know your calendar. None of them know your wanting.</h2>
          <p class="sub reveal">We built the one that reads both, in private, for solo, couples and consenting groups.</p>
          <ol class="steps">
            <li class="step reveal">
              <span class="step-n">01</span>
              <h3 class="step-h">Track what you feel</h3>
              <p class="step-b">Desire, mood, energy, who you were with. The honest details, logged in seconds.</p>
            </li>
            <li class="step reveal">
              <span class="step-n">02</span>
              <h3 class="step-h">See your rhythm</h3>
              <p class="step-b">A menstrual-cycle tracker that learns your phases and patterns over time.</p>
            </li>
            <li class="step reveal">
              <span class="step-n">03</span>
              <h3 class="step-h">Understand the two</h3>
              <p class="step-b">Cycle-aware insight into how your phase shapes your desire. The part no one else shows you.</p>
            </li>
          </ol>
        </div>
      </section>

      <!-- ===================== 02 THE CYCLE ===================== -->
      <section class="block insight" id="cycle">
        <header class="block-head"><span class="num">02</span><span class="lbl">The cycle</span></header>
        <div class="block-body insight-body">
          <div class="insight-copy">
            <h2 class="big reveal">Your desire has a rhythm. We help you read it.</h2>
            <p class="sub reveal">Four phases, one rhythm, drawn in your own private light. A typical cycle, shown for illustration.</p>
            <ul class="phase-legend reveal">
              <li><span class="swatch" style="--c: var(--menstrual)"></span> Menstrual</li>
              <li><span class="swatch" style="--c: var(--follicular)"></span> Follicular</li>
              <li><span class="swatch" style="--c: var(--ovulatory)"></span> Ovulatory</li>
              <li><span class="swatch" style="--c: var(--luteal)"></span> Luteal</li>
            </ul>
          </div>
          <div class="insight-art reveal">
            <svg class="ring" viewBox="0 0 420 420" role="img" aria-label="Your intimacy and your cycle drawn together as a ring of phases.">
              <defs>
                <linearGradient id="phaseGrad" x1="0" y1="0" x2="1" y2="1">
                  <stop offset="0%" stop-color="var(--menstrual)" />
                  <stop offset="34%" stop-color="var(--follicular)" />
                  <stop offset="67%" stop-color="var(--ovulatory)" />
                  <stop offset="100%" stop-color="var(--luteal)" />
                </linearGradient>
                <filter id="soften" x="-30%" y="-30%" width="160%" height="160%"><feGaussianBlur stdDeviation="2" /></filter>
              </defs>
              <g class="ring-rotate">
                <circle class="ring-track" cx="210" cy="210" r="160" fill="none" />
                <circle class="ring-arc" cx="210" cy="210" r="160" fill="none" />
                <circle class="ring-dot" r="7" cx="210" cy="50" />
              </g>
            </svg>
          </div>
        </div>
      </section>

      <!-- ===================== 03 PRIVATE ===================== -->
      <section class="block private" id="private">
        <header class="block-head"><span class="num">03</span><span class="lbl">Private</span></header>
        <div class="block-body">
          <h2 class="big reveal">Private by design, not a promise you have to trust.</h2>
          <ul class="vow">
            <li class="reveal">Encrypted in transit and at rest.</li>
            <li class="reveal">Never sold, never shared with anyone.</li>
            <li class="reveal">No third-party ad or analytics on your intimate data.</li>
            <li class="reveal">Yours to export or delete, anytime.</li>
          </ul>
        </div>
      </section>

      <!-- ===================== 04 JOIN ===================== -->
      <section class="block join" id="join">
        <header class="block-head"><span class="num">04</span><span class="lbl">Join</span></header>
        <div class="block-body">
          <h2 class="big reveal">Be first in.</h2>
          <p class="sub reveal">Your invitation arrives before the door opens.</p>
          <form class="waitlist reveal" aria-label="Join the waitlist">
            <label class="sr-only" for="email-join">Your email address</label>
            <div class="field">
              <input id="email-join" type="email" name="email" inputmode="email" autocomplete="email" required placeholder="you@email.com" aria-describedby="note-join" />
              <button type="submit" class="cta" data-cursor><span>Get early access</span><span class="arr">&rarr;</span></button>
            </div>
            <p class="form-note" id="note-join" role="status" aria-live="polite"></p>
          </form>
          <p class="trust reveal">Private by design <span class="d">/</span> 17+ <span class="d">/</span> no spam, leave anytime</p>
        </div>
      </section>
    </main>

    <footer class="foot">
      <div class="foot-top">
        <span class="foot-mark">igasm</span>
        <p class="foot-line">A private companion for your intimacy and your cycle. Coming soon to iOS and Android.</p>
      </div>
      <div class="foot-base">
        <a href="https://igasm.in" data-cursor>igasm.in</a>
        <a href="mailto:admin@igasm.in" data-cursor>admin@igasm.in</a>
        <span>Informational wellness for 17+. Encrypted, never sold.</span>
        <span>&copy; 2026 igasm</span>
      </div>
    </footer>

    <script src="vendor/gsap.min.js" defer></script>
    <script src="vendor/ScrollTrigger.min.js" defer></script>
    <script src="vendor/lenis.min.js" defer></script>
    <script type="module" src="main.js"></script>
  </body>
</html>
